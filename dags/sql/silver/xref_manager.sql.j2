-- =============================================================================
-- Silver: xref_manager   (Jinja-template — `.sql.j2`)
-- =============================================================================
-- Manager (head-coach) cross-reference. Three sources (#144, TM added by the
-- xref-improvements pass):
--   * FBref         — iceberg.bronze.fbref_match_managers (scorebox parser,
--                     scrapers/fbref/parsers/finders.py::parse_match_managers).
--                     Spine; has only a manager NAME (no stable id).
--   * FotMob        — native iceberg.bronze.fotmob_squad_snapshots_current
--                     WHERE member_type='coach' (#930 cutover). The live squad
--                     row is the identity driver: member_id is the STABLE
--                     coachId kept verbatim in source_id and member_name is the
--                     cross-source glue. The global player snapshot is only a
--                     LEFT name fallback because some valid squad coachIds have
--                     no player-snapshot row. League/season scope comes from
--                     `coach_scope` (current squad × season_teams).
--   * Transfermarkt — native iceberg.bronze.transfermarkt_coach_stints plus
--                     transfermarkt_coach_profiles. Carries a STABLE coach_id
--                     (source_id); league/season scope comes from the native
--                     squad membership for the stint's club. Global dob /
--                     nationality are consumed downstream through the bridge.
--
-- Cross-source identity — match cascade (strongest first):
--   1. name_alias     — manager_aliases.yaml override (human-curated raw form →
--                       spine canonical_id; heals surname-first "Le Bris, Régis"
--                       and other mis-normalising spellings).
--   2. name_normalize — identical diacritic-stripping name-normalize slug on
--                       both sides (FBref "Mikel Arteta" == TM "Mikel Arteta").
--   3. name_initial   — (surname, first-initial) equality, UNIQUE within
--                       (league, season) on BOTH sides (TM "M. Arteta" →
--                       ('arteta', 'm') → spine "Mikel Arteta"). Ambiguity
--                       guards: a spine (surname, initial) key claimed by two
--                       coaches is dropped from the key set (HAVING), and a TM
--                       coach sharing its key with another TM coach in the same
--                       (league, season) may not claim it (initial_key_dup).
--   4. orphan         — no tier matched; canonical_id stays the source's own
--                       name slug (surfaced by the Phase 2 orphan-rate report
--                       and the manager_aliases.yaml DISCOVERY workflow).
--
-- Why name-normalize + a curated dictionary, not a rapidfuzz resolver
-- (cf. xref_player): managers are tiny (~20-30 per league-season) and mostly
-- spelled identically across sources; a full fuzzy resolver is
-- over-engineering here. canonical_id stays NAME-based (not coachId-anchored)
-- on purpose — anchoring on an id would rewrite every existing FBref
-- canonical_id and change dim_manager output, breaking the "refactor without
-- behaviour change" contract. Source ids are preserved in source_id for a
-- future ID-anchor endgame (mirrors xref_team team_id, #141).
--
-- DOB corroboration is intentionally NOT part of this CTAS (schema frozen,
-- Bronze-only inputs): TM-vs-FotMob dob disagreement per canonical is a DQ
-- WARNING — see xref_dq.evaluate_manager_dob_collisions (strongest signal
-- exactly for name_initial rows).
--
-- Alias VALUES are rendered from configs/medallion/manager_aliases.yaml via
-- `medallion_config.get_manager_alias_sql_values(source=None)` into the single
-- `manager_aliases_values_sql` placeholder (same machinery as
-- xref_team.sql.j2 / xref_referee.sql.j2). source=None merges the `_generic`
-- bucket with every per-source bucket: an alias keyed on a TM spelling simply
-- never matches a FotMob name — safe no-op.
--
-- DAG-integration note: rendered by `dag_transform_xref._run_xref_manager`
-- into a tempfile, then wrapped in `CREATE OR REPLACE TABLE
-- iceberg.silver.xref_manager AS ...` via `silver_tasks.run_silver_transform()`.
-- This file MUST stay a pure SELECT.
--
-- =============================================================================
-- Schema (frozen — identical to xref_team / xref_referee)
-- =============================================================================
--   canonical_id   varchar  -- LOWER(REGEXP_REPLACE(strip_diacritics(name),'[^a-zA-Z0-9]+','_'))
--   source         varchar  -- 'fbref' | 'fotmob' | 'transfermarkt'
--   source_id      varchar  -- FBref: raw manager_name; FotMob: coachId; TM: coach_id
--   display_name   varchar  -- raw name as stored in the source
--   league         varchar
--   season         varchar  -- slug ('2425'); FBref Bronze stores BIGINT,
--                           -- FotMob native derives the slug ONCE in the
--                           -- framework's season_axis (source_season_key),
--                           -- TM Bronze already stores the slug varchar
--   confidence     varchar  -- 'name_alias' | 'name_normalize' | 'name_initial' | 'orphan'
--   match_score    double   -- always NULL (no fuzzy scoring)
--
-- Testable invariants (xref_dq.build_xref_manager_checks):
--   * PK = (source, source_id, league, season).
--   * canonical_id is NEVER NULL.
--   * source ∈ {'fbref', 'fotmob', 'transfermarkt'}.
--   * confidence ∈ {'name_alias', 'name_normalize', 'name_initial', 'orphan'}.
--   * Every LEFT JOIN target below is pre-collapsed to 1 row per join key —
--     the TM block's row count equals tm_coach's by construction (no fan-out).
-- =============================================================================

WITH
-- ============================================================================
-- [CUTOVER-FRAMEWORK #930] Сезонный скоуп для глобальных native-снапшотов.
-- Синхронизируемая копия: НЕ менять имена CTE и выражение season-слага.
-- League-map source of truth: configs/fotmob/competitions.json.
-- Season-scope framework reference: /root/fotmob-runtime/cutover-framework.md
-- ============================================================================

-- 1) Обратная карта competition_id -> legacy league. INNER JOIN к ней — это
--    ОДНОВРЕМЕННО скоуп-фильтр 14 лиг (native-каталог шире; см. пределы).
league_map (competition_id, league) AS (
    VALUES
        {{ fotmob_league_map_values_sql }}
),

-- 2) Ось сезонов: (competition_id, source_season_key) -> (league, season)
--    + флаг текущего сезона. ЕДИНСТВЕННОЕ место вычисления season-слага.
--    Правило season-ключа:
--      * season_year = TRY_CAST(substr(source_season_key, 1, 4) AS integer) —
--        корректно для обеих форм ключа ('2025/2026' -> 2025, '2025' -> 2025);
--      * слаг — СУЩЕСТВУЮЩИЙ legacy-CASE по league, НИКОГДА не по форме ключа
--        (single-year ключ AFCON обязан дать '2526', а не '2025' — иначе
--        битовое расхождение с legacy silver и разрыв JOIN'ов xref);
--      * is_current_season = is_selected OR is_latest (то, что источник сейчас
--        показывает по умолчанию; live: comp 47 -> '2026/2027').
season_axis AS (
    SELECT
        CAST(cs.competition_id AS bigint)  AS competition_id,   -- в этой таблице varchar
        cs.source_season_key,
        lm.league,
        TRY_CAST(substr(cs.source_season_key, 1, 4) AS integer) AS season_year,
        CASE WHEN lm.league = 'INT-World Cup'
             THEN LPAD(CAST(TRY_CAST(substr(cs.source_season_key, 1, 4) AS integer)
                            AS varchar), 4, '0')
             ELSE LPAD(CAST(MOD(TRY_CAST(substr(cs.source_season_key, 1, 4) AS integer),
                                100) AS varchar), 2, '0')
               || LPAD(CAST(MOD(TRY_CAST(substr(cs.source_season_key, 1, 4) AS integer) + 1,
                                100) AS varchar), 2, '0')
        END                                AS season,
        (cs.is_selected OR cs.is_latest)   AS is_current_season
    FROM iceberg.bronze.fotmob_competition_seasons_current cs
    JOIN league_map lm
      ON lm.competition_id = CAST(cs.competition_id AS bigint)
),

-- 3) Вселенная команд сезона (season_teams УЖЕ per-season, скоуп не нужен —
--    только league/season-атрибуция). team_id здесь bigint.
team_scope AS (
    SELECT
        sa.league,
        sa.season,
        sa.competition_id,
        sa.source_season_key,
        sa.is_current_season,
        st.team_id,                        -- bigint
        st.team_name
    FROM iceberg.bronze.fotmob_season_teams_current st
    JOIN season_axis sa
      ON  sa.competition_id    = st.competition_id
      AND sa.source_season_key = st.source_season_key
),

-- 4) ТЕКУЩИЙ сезон: членство из живого ростера. squad_snapshots — глобальный
--    снапшот «сейчас» (field_map: observed roster, never historical), поэтому
--    клеится ТОЛЬКО к is_current_season — иначе сегодняшний состав налипнет
--    на прошлые сезоны (легаси-баг seasonless_source_snapshot_replicated_as_
--    _historical, который migrate_fotmob_native.py карантинит).
squad_scope AS (
    SELECT DISTINCT
        ts.league,
        ts.season,
        ts.competition_id,
        ts.source_season_key,
        ts.team_id,                        -- bigint
        sq.member_id,                      -- varchar (= legacy player_id в varchar)
        sq.member_type                     -- 'player' | 'coach' (live: только эти два)
    FROM team_scope ts
    JOIN iceberg.bronze.fotmob_squad_snapshots_current sq
      ON CAST(sq.team_id AS bigint) = ts.team_id   -- squad.team_id -- varchar!
    WHERE ts.is_current_season
),

-- 5) ИСТОРИЯ (и текущий сезон тоже): членство игроков из per-season
--    лидербордов — ровно та вселенная, по которой legacy silver реально
--    отдавал статистику (LEFT JOIN stats). competition_id здесь bigint.
lb_player_scope AS (
    SELECT DISTINCT
        sa.league,
        sa.season,
        sa.competition_id,
        sa.source_season_key,
        lb.team_id,                            -- bigint: клуб игрока в сезоне
        CAST(lb.participant_id AS varchar)     AS member_id
    FROM iceberg.bronze.fotmob_leaderboards_current lb
    JOIN season_axis sa
      ON  sa.competition_id    = lb.competition_id
      AND sa.source_season_key = lb.source_season_key
    WHERE lb.participant_type = 'player'
),

-- 6) Итоговое членство ИГРОКА в (лиге, сезоне): текущий сезон — ростер,
--    история — лидерборды. UNION дедупит пересечение. team_id намеренно НЕ
--    выносится (между ветками может отличаться при переходе внутри сезона) —
--    клуб потребители берут из своей ветки (squad_scope / lb_player_scope).
player_scope AS (
    SELECT DISTINCT league, season, competition_id, source_season_key, player_id
    FROM (
        SELECT league, season, competition_id, source_season_key,
               member_id AS player_id
        FROM squad_scope
        WHERE member_type = 'player'
        UNION ALL
        SELECT league, season, competition_id, source_season_key, member_id
        FROM lb_player_scope
    )
),

-- 7) Членство ТРЕНЕРА: только текущий сезон через клуб (в лидербордах
--    тренеров нет; исторической глубины тренеров в native НЕТ — как и в
--    legacy, где squad тоже был снапшотом «сейчас»).
coach_scope AS (
    SELECT
        league,
        season,
        competition_id,
        source_season_key,
        team_id,                           -- bigint
        member_id AS coach_id              -- varchar (= coachId = player_id)
    FROM squad_scope
    WHERE member_type = 'coach'
),

-- ОПЦИОНАЛЬНО (НЕ включать в cutover без решения владельца): расширение
-- исторической вселенной всеми, кто попал в player-статистику матчей.
-- Живьём шире лидербордов (comp 289 сезон '2023': 653 vs 510 игроков).
-- , match_player_scope AS (
--     SELECT DISTINCT
--         sa.league, sa.season, sa.competition_id, sa.source_season_key,
--         t.pid AS member_id                 -- varchar (ключи player_stats_json)
--     FROM iceberg.bronze.fotmob_match_payloads_current p
--     JOIN season_axis sa
--       ON  sa.competition_id    = CAST(p.competition_id AS bigint)  -- payloads: varchar!
--       AND sa.source_season_key = p.source_season_key
--     CROSS JOIN UNNEST(
--         map_keys(CAST(json_parse(p.player_stats_json) AS map(varchar, json)))
--     ) AS t(pid)
--     WHERE p.player_stats_json IS NOT NULL
--       AND p.player_stats_json <> 'null'
--       AND p.player_stats_json <> '{}'
-- )
-- ============================================================================
-- [/CUTOVER-FRAMEWORK]
-- ============================================================================

manager_aliases AS (
    -- Curated overrides (tier 1). One row per (norm, league); MAX guards the
    -- LEFT JOINs against fan-out (#465). NB: two different canonical_ids on
    -- one (norm, league) would be silently collapsed by MAX — keep the YAML
    -- free of norm collisions (documented in its header).
    SELECT
        league,
        LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(raw_name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_'))                 AS norm,
        MAX(canonical_id)                          AS canonical_id
    FROM (VALUES
        {{ manager_aliases_values_sql }}
    ) AS t(raw_name, canonical_id, league)
    -- NB Trino: GROUP BY cannot reference the same-level SELECT alias `norm`
    -- (COLUMN_NOT_FOUND), so the expression is repeated.
    GROUP BY
        LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(raw_name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_')),
        league
),

fbref_spine AS (
    -- Season-grained spine (needed by the name_initial tier). DISTINCT — the
    -- Bronze table is match-grain (~38 rows per manager-season).
    SELECT DISTINCT
        LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(manager_name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_'))                              AS canonical_id,
        league,
        -- #913 Phase 2
        CASE WHEN REGEXP_LIKE(COALESCE(source_season_id, ''), '^\d{4}$')
             THEN source_season_id
             WHEN REGEXP_LIKE(COALESCE(source_season_id, ''), '^\d{4}-\d{4}$')
             THEN SUBSTR(source_season_id, 3, 2) || SUBSTR(source_season_id, 8, 2)
             WHEN NULLIF(TRIM(source_season_id), '') IS NOT NULL
             THEN TRIM(source_season_id)
             WHEN league = 'INT-World Cup'
             THEN LPAD(CAST(season AS varchar), 4, '0')
             ELSE LPAD(CAST(MOD(season, 100) AS varchar), 2, '0')
                  || LPAD(CAST(MOD(season + 1, 100) AS varchar), 2, '0')
        END AS season
    FROM iceberg.bronze.fbref_match_managers
    WHERE manager_name IS NOT NULL AND manager_name <> ''
),

fbref_canon AS (
    -- Distinct FBref canonical_ids per league — the name_normalize glue target
    -- for FotMob / TM. DISTINCT keeps the LEFT JOINs below 1:1 (no fan-out).
    SELECT DISTINCT canonical_id, league
    FROM fbref_spine
),

fbref_initial_keys AS (
    -- name_initial tier target: (surname-token, first-initial) that maps to
    -- EXACTLY ONE spine canonical within (league, season). HAVING is the
    -- spine-side ambiguity guard: two spine coaches sharing (surname, initial)
    -- drop out entirely, so the tier can never mis-assign between them.
    SELECT
        league,
        season,
        element_at(split(canonical_id, '_'), -1)                AS surname,
        substr(canonical_id, 1, 1)                              AS first_initial,
        MAX(canonical_id)                                       AS canonical_id
    FROM fbref_spine
    GROUP BY
        league,
        season,
        element_at(split(canonical_id, '_'), -1),
        substr(canonical_id, 1, 1)
    HAVING COUNT(DISTINCT canonical_id) = 1
),

fotmob_coach AS (
    -- One coach row per (member_id, league, season), driven by the current
    -- squad. ROW_NUMBER collapses a coach serving two clubs in one season.
    -- player_snapshots is deliberately LEFT-only: a missing profile must not
    -- erase a valid squad coach (the production zero-manager regression).
    SELECT player_id, name, league, season
    FROM (
        SELECT
            sq.member_id AS player_id,
            COALESCE(
                NULLIF(TRIM(sq.member_name), ''),
                NULLIF(TRIM(ps.name), '')
            ) AS name,
            cs.league,
            cs.season,
            ROW_NUMBER() OVER (
                PARTITION BY sq.member_id, cs.league, cs.season
                ORDER BY sq._observed_at DESC, sq._target_batch_id DESC
            ) AS rn
        FROM coach_scope cs
        JOIN iceberg.bronze.fotmob_squad_snapshots_current sq
          ON  sq.member_id = cs.coach_id
          AND CAST(sq.team_id AS bigint) = cs.team_id
          AND sq.member_type = 'coach'
        LEFT JOIN iceberg.bronze.fotmob_player_snapshots_current ps
          ON  ps.player_id = sq.member_id
          AND ps.is_coach
        WHERE COALESCE(
            NULLIF(TRIM(sq.member_name), ''),
            NULLIF(TRIM(ps.name), '')
        ) IS NOT NULL
    )
    WHERE rn = 1
),

tm_profile AS (
    -- Native profiles are global and append-safe. Collapse defensively before
    -- joining stints so a retried batch cannot fan out the scoped coach row or
    -- make the name fallback depend on planner order.
    SELECT coach_id, name
    FROM (
        SELECT
            CAST(coach_id AS varchar)                           AS coach_id,
            name,
            ROW_NUMBER() OVER (
                PARTITION BY CAST(coach_id AS varchar)
                ORDER BY _ingested_at DESC, _batch_id DESC
            )                                                   AS rn
        FROM iceberg.bronze.transfermarkt_coach_profiles
        WHERE coach_id IS NOT NULL
    )
    WHERE rn = 1
),

tm_coach AS (
    -- One coach row per (coach_id, league, season). Coach stints are global,
    -- so league/season is projected only through a native membership of the
    -- same club; this recreates the resolver scope without restoring the
    -- legacy coach snapshot table. Profiles provide a name fallback for a
    -- stint whose page omitted it.
    SELECT
        coach_id,
        name,
        league,
        season,
        norm,
        -- TM-side ambiguity guard for name_initial: if two TM coaches in one
        -- (league, season) share (surname, initial), neither may claim the key.
        COUNT(*) OVER (
            PARTITION BY league, season,
                         element_at(split(norm, '_'), -1),
                         substr(norm, 1, 1)
        )                                                       AS initial_key_dup
    FROM (
        SELECT
            CAST(s.coach_id AS varchar)                         AS coach_id,
            COALESCE(s.name, p.name)                            AS name,
            m.league,
            m.season,
            LOWER(REGEXP_REPLACE(
                REGEXP_REPLACE(
                    NORMALIZE(COALESCE(s.name, p.name), NFD), '\p{Mn}+', ''),
                '[^a-zA-Z0-9]+', '_'))                          AS norm,
            ROW_NUMBER() OVER (
                PARTITION BY s.coach_id, m.league, m.season
                ORDER BY s._ingested_at DESC, s._batch_id DESC
            )                                                   AS rn
        FROM iceberg.bronze.transfermarkt_coach_stints s
        JOIN (
            SELECT DISTINCT
                CAST(club_id AS varchar) AS club_id,
                league,
                season,
                TRY_CAST(
                    CONCAT('20', SUBSTR(season, 1, 2), '-07-01') AS date
                ) AS season_start,
                TRY_CAST(
                    CONCAT('20', SUBSTR(season, 3, 2), '-06-30') AS date
                ) AS season_end
            FROM iceberg.bronze.transfermarkt_squad_memberships
            WHERE club_id IS NOT NULL
              AND REGEXP_LIKE(season, '^[0-9]{4}$')
        ) m ON m.club_id = CAST(s.club_id AS varchar)
        LEFT JOIN tm_profile p
          ON CAST(p.coach_id AS varchar) = CAST(s.coach_id AS varchar)
        WHERE s.coach_id IS NOT NULL
          AND COALESCE(s.name, p.name) IS NOT NULL
          AND COALESCE(s.name, p.name) <> ''
          -- A global club history must not attach every coach ever employed
          -- by that club to every requested season. Unknown/invalid intervals
          -- fail closed instead of being treated as all-season tenures.
          AND (s.appointed_date IS NOT NULL OR s.left_date IS NOT NULL)
          AND (
              s.appointed_date IS NULL
              OR TRY_CAST(s.appointed_date AS date) <= m.season_end
          )
          AND (
              s.left_date IS NULL
              OR TRY_CAST(s.left_date AS date) >= m.season_start
          )
    )
    WHERE rn = 1
),

tm_resolved AS (
    SELECT
        t.coach_id,
        t.name,
        t.league,
        t.season,
        t.norm,
        a.canonical_id                                          AS alias_cid,
        fc.canonical_id                                         AS exact_cid,
        CASE WHEN t.initial_key_dup = 1
             THEN fik.canonical_id END                          AS initial_cid
    FROM tm_coach t
    LEFT JOIN manager_aliases a
        ON  a.league = t.league
        AND a.norm   = t.norm
    LEFT JOIN fbref_canon fc
        ON  fc.canonical_id = t.norm
        AND fc.league       = t.league
    LEFT JOIN fbref_initial_keys fik
        ON  fik.league        = t.league
        AND fik.season        = t.season
        AND fik.surname       = element_at(split(t.norm, '_'), -1)
        AND fik.first_initial = substr(t.norm, 1, 1)
)

-- ===== fbref (spine) =====
SELECT
    -- Transliterate diacritics before slugging (issue #201): FBref emits the
    -- same manager name both with and without accents ("Régis Le Bris" vs
    -- "Regis Le Bris"). A bare `[^a-zA-Z0-9]+ -> _` collapses each accent to
    -- '_', so the two spellings yield DIFFERENT canonical_ids and dim_manager's
    -- LAG-based stint detector then splits one continuous stint into several,
    -- breaking the (manager, team, valid_from) PK. NORMALIZE(NFD) decomposes
    -- "é" -> "e" + combining mark, `\p{Mn}+` strips the mark, leaving ASCII
    -- "e". Same idiom as xref_team.sql.j2.
    LOWER(REGEXP_REPLACE(
        REGEXP_REPLACE(NORMALIZE(manager_name, NFD), '\p{Mn}+', ''),
        '[^a-zA-Z0-9]+', '_'))                                  AS canonical_id,
    'fbref'                                                     AS source,
    manager_name                                                AS source_id,
    manager_name                                                AS display_name,
    league,
    -- season → slug ('2425'); bronze fbref_match_managers is year-start bigint (#404).
    -- #913 Phase 2
    CASE WHEN REGEXP_LIKE(COALESCE(source_season_id, ''), '^\d{4}$')
         THEN source_season_id
         WHEN REGEXP_LIKE(COALESCE(source_season_id, ''), '^\d{4}-\d{4}$')
         THEN SUBSTR(source_season_id, 3, 2) || SUBSTR(source_season_id, 8, 2)
         WHEN NULLIF(TRIM(source_season_id), '') IS NOT NULL
         THEN TRIM(source_season_id)
         WHEN league = 'INT-World Cup'
         THEN LPAD(CAST(season AS varchar), 4, '0')
         ELSE LPAD(CAST(MOD(season, 100) AS varchar), 2, '0')
              || LPAD(CAST(MOD(season + 1, 100) AS varchar), 2, '0')
    END  AS season,
    'name_normalize'                                            AS confidence,
    CAST(NULL AS double)                                        AS match_score
FROM iceberg.bronze.fbref_match_managers
WHERE manager_name IS NOT NULL AND manager_name <> ''
GROUP BY
    -- Group by the OUTPUT columns (ordinals), never the raw inputs. The season
    -- slug is a function of BOTH raw columns: a legacy row (season=2025,
    -- source_season_id=NULL) and a row from the production pipeline (season=2025,
    -- source_season_id='2025-2026') both render '2526', but grouping by the raw
    -- pair kept them in separate groups and emitted the same manager twice —
    -- the duplicate the xref PK gate (correctly) refuses.
    1, 3, 4, 5, 6

UNION ALL

-- ===== fotmob (coachId mirror) =====
SELECT
    -- Alias override wins over the coach's own name slug (heals the same
    -- mis-normalising spellings as the TM block; a TM-only raw form simply
    -- never matches — safe no-op).
    COALESCE(
        a.canonical_id,
        LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(d.name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_'))
    )                                                           AS canonical_id,
    'fotmob'                                                    AS source,
    CAST(d.player_id AS varchar)                                AS source_id,
    d.name                                                      AS display_name,
    d.league,
    -- season is ALREADY the '2425' slug — computed once in the framework's
    -- season_axis (#930 cutover; the #404/#913 legacy-CASE lives there,
    -- including the INT-World Cup 4-digit branch — bit-compatible). Files may
    -- not re-derive the slug outside the framework.
    d.season,
    -- 'name_alias' when a curated alias fired; 'name_normalize' when this
    -- coach glues to an FBref canonical in the same league; 'orphan' otherwise
    -- (surfaced by the Phase 2 orphan-rate report).
    CASE WHEN a.canonical_id IS NOT NULL THEN 'name_alias'
         WHEN fc.canonical_id IS NOT NULL THEN 'name_normalize'
         ELSE 'orphan'
    END                                                         AS confidence,
    CAST(NULL AS double)                                        AS match_score
FROM fotmob_coach d
LEFT JOIN manager_aliases a
    ON  a.league = d.league
    AND a.norm = LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(d.name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_'))
LEFT JOIN fbref_canon fc
    ON  fc.canonical_id = LOWER(REGEXP_REPLACE(
            REGEXP_REPLACE(NORMALIZE(d.name, NFD), '\p{Mn}+', ''),
            '[^a-zA-Z0-9]+', '_'))
    AND fc.league = d.league

UNION ALL

-- ===== transfermarkt (coach_id + dob/nationality carrier) =====
SELECT
    COALESCE(t.alias_cid, t.exact_cid, t.initial_cid, t.norm)   AS canonical_id,
    'transfermarkt'                                             AS source,
    t.coach_id                                                  AS source_id,
    t.name                                                      AS display_name,
    t.league,
    t.season,
    CASE WHEN t.alias_cid   IS NOT NULL THEN 'name_alias'
         WHEN t.exact_cid   IS NOT NULL THEN 'name_normalize'
         WHEN t.initial_cid IS NOT NULL THEN 'name_initial'
         ELSE 'orphan'
    END                                                         AS confidence,
    CAST(NULL AS double)                                        AS match_score
FROM tm_resolved t
