-- =============================================================================
-- Gold: dim_competition  (Jinja template, rendered by dim_loaders.py)
-- =============================================================================
-- Static dimension of football competitions. One row per league (incl. stubs
-- for not-yet-ingested leagues — a dictionary lists what exists, not what we
-- already scraped). Aligned to the star-schema design (issue #425).
--
-- Source:       configs/medallion/competitions.yaml -> rendered into VALUES
--               rows by dags/utils/dim_loaders.py::render_dim_competition_sql()
-- PK:           league  (slug, e.g. 'ENG-Premier League' — same value as the
--               `league` column on every fact, so JOINs need no mapping)
-- Partitioning: NONE  (8-row config-driven dim)
--
-- The {{ rows }} placeholder is substituted by render_dim_competition_sql();
-- one tuple per competition listed in competitions.yaml.
-- Each tuple MUST follow the column order declared in the AS t(...) clause.
-- =============================================================================

select * from (values
{{ rows }}
) as t(
    league,                   -- PK, slug e.g. 'ENG-Premier League'
    competition_name,         -- e.g. 'English Premier League'
    country,                  -- e.g. 'England' ('Europe' for UEFA cups)
    tier,                     -- 1 = top flight
    competition_format,       -- 'league_round_robin' | 'group_knockout' (#913 Phase 3)
    is_international          -- true for INT- competitions (WC etc.)
)
