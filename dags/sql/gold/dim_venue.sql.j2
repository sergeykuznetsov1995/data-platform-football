-- =============================================================================
-- Gold: dim_venue   (Jinja-template — `.sql.j2`)
-- =============================================================================
-- Global dimension of football venues (stadiums) consolidated from FBref and
-- ESPN match feeds. One row per canonical venue.
--
-- Sources:
--   iceberg.silver.fbref_match_enriched   (sch.venue per match)
--   iceberg.silver.espn_matchsheet        (conform: venue per match, dedup'd #735)
--   iceberg.silver.fotmob_team_profile    (venue-attribute lookup only, #719 coords +
--                                          #750 city/surface/capacity/opened — does NOT
--                                          contribute venue rows; grain unchanged)
--   iceberg.silver.sofascore_venue        (venue-attribute lookup only, #753:
--                                          city/country/coords per match — does NOT
--                                          contribute venue rows; grain unchanged)
--
-- Identity (issue #145): `venue_id` is the explicit `venue_<slug>` from
-- `configs/medallion/venue_aliases.yaml` — NOT a hash of the raw name. The
-- template renders ONE `{{ venue_aliases_values_sql }}` placeholder, filled by
-- `medallion_config.get_venue_alias_sql_values(include_capacity=True)` → a list of
-- seven-tuples `('raw_name','canonical_id','canonical_name','city','country',
-- 'league', capacity), ...`. Every observed spelling of a stadium carries an alias row
-- pointing at the same `canonical_id`, so "Brentford Community Stadium" and
-- "Gtech Community Stadium" (sponsor rename) merge with zero fuzzy matching.
--
-- Unmatched raw names fall back to a normalised-name hash id and are marked
-- `venue_source = 'orphan'` — a DQ WARNING surfaces them for the curator.
--
-- DAG-integration note: rendered by `dim_loaders.render_dim_venue_sql` →
-- tempfile → `run_inline_ctas` → `CREATE OR REPLACE TABLE iceberg.gold.dim_venue`
-- via `gold_tasks.run_gold_transform`. This file MUST stay a pure SELECT.
--
-- PK:           venue_id   (guaranteed unique by the final GROUP BY)
-- Partitioning: NONE  (small global dim, queried by venue_id)
--
-- Output columns (star-schema design, issue #425):
--   venue_name   = canonical_name from YAML, else MAX(name) fbref > espn
--   city         = curated venue_aliases.yaml, else FotMob (#750), else SofaScore (#753)
--   country      = curated venue_aliases.yaml, else SofaScore event.venue (#753)
--   capacity     = COALESCE(FotMob, curated fallback) (#750): FotMob
--                  silver.fotmob_team_profile is primary (replaced bulk of #434);
--                  small curated fallback remains for moved grounds FotMob can't
--                  supply. NULL only when neither source has it.
--   surface/opened = FotMob venue.statPairs (#750); NULL when no FotMob match
--   latitude/longitude = stadium coords: FotMob silver.fotmob_team_profile (#719)
--                  primary, SofaScore silver.sofascore_venue (#753) fills NULLs;
--                  matched by normalised venue name. NULL when neither matches.
--                  Feeds flight-distance features for the home-advantage study (#558).
--   venue_source = 'curated' (matched alias) | 'orphan' (unmatched) — kept
--                  for the orphan-rate DQ check in validate_gold_quality
--
-- Notes:
--   * city: curated venue_aliases.yaml wins; FotMob fills NULLs for non-curated /
--     orphan venues (#750); SofaScore fills any remaining (#753). country: curated
--     wins, SofaScore event.venue fills the rest (#753).
--   * Normalisation key (NFD + strip diacritics + remove non-alphanumerics)
--     folds apostrophe/period variants ("St James' Park" / "St. James' Park")
--     automatically, so the curator only lists genuinely distinct spellings.
--   * ESPN season is a 4-char slug label ('2526'); kept as-is to align with
--     silver/FBref season, now also slug varchar after #404.
-- =============================================================================

with aliases as (
    select
        raw_name,
        canonical_id,
        canonical_name,
        city,
        country,
        -- League predicate (issue #148): guard the JOIN on a.league = u.league
        -- so worldwide namesakes (one spelling, two cities) never cross-merge.
        league,
        -- capacity (issue #750): CURATED FALLBACK only — COALESCE'd BEHIND FotMob in
        -- the final SELECT, kept just for venues FotMob's current-ground team-profile
        -- can't supply (moved grounds). 7th UNQUOTED col (include_capacity=True).
        capacity,
        -- Normalised join key: lower -> strip diacritics (NFD + \p{Mn}) ->
        -- remove all non-alphanumerics. Same idiom as xref_referee.sql.j2.
        regexp_replace(
            regexp_replace(normalize(lower(raw_name), NFD), '\p{Mn}+', ''),
            '[^a-z0-9]+', ''
        ) as norm
    from (values
        {{ venue_aliases_values_sql }}
    ) as t(raw_name, canonical_id, canonical_name, city, country, league, capacity)
),

fbref_venues as (
    select
        trim(venue)                                  as venue_raw,
        league,
        season,
        date                                         as match_date,
        'fbref'                                      as src
    from iceberg.silver.fbref_match_enriched
    where venue is not null
      and trim(venue) <> ''
),

-- ESPN venue feed now one-hop from Silver (issue #735): silver.espn_matchsheet
-- already trims venue, dedups per match (latest snapshot) and derives match_date,
-- so this CTE mirrors fbref_venues — no bronze read, no ROW_NUMBER here.
espn_venues as (
    select
        trim(venue)                                  as venue_raw,
        league,
        season,  -- silver.espn_matchsheet keeps bronze slug '2526' (#404)
        match_date,
        'espn'                                       as src
    from iceberg.silver.espn_matchsheet
    where venue is not null
      and trim(venue) <> ''
),

-- FotMob venue enrichment (#719 coords + #750 city/surface/capacity/opened): keyed by
-- (league, normalised venue name). Enrichment lookup ONLY — joined into `resolved`,
-- never UNION'd into the venue feed, so dim_venue's one-row-per-venue grain is
-- untouched. Same norm idiom as the alias join; (league, norm) guards worldwide
-- namesakes. No coords filter (#750) — attributes may exist without coords; MAX
-- ignores NULLs, so each attribute is aggregated independently.
fotmob_venue as (
    select
        league,
        regexp_replace(
            regexp_replace(normalize(lower(trim(venue)), NFD), '\p{Mn}+', ''),
            '[^a-z0-9]+', ''
        )                                            as norm,
        max(venue_latitude)                          as latitude,
        max(venue_longitude)                         as longitude,
        max(venue_city)                              as city,
        max(venue_surface)                           as surface,
        max(venue_capacity)                          as capacity,
        max(venue_opened)                            as opened
    from iceberg.silver.fotmob_team_profile
    where venue is not null
      and trim(venue) <> ''
    group by 1, 2
),

-- SofaScore venue enrichment (#753): per-match `event.venue` → historically
-- accurate stadium (NO current-ground bias — fills moved grounds FotMob's
-- team-profile mislabels: Goodison Park / White Hart Lane). Keyed by (league,
-- normalised stadium name) like fotmob_venue; enrichment lookup ONLY (joined
-- into `resolved`, never UNION'd — one-row-per-venue grain untouched). MAX
-- ignores NULLs, so each attribute aggregates independently.
sofascore_venue as (
    select
        league,
        regexp_replace(
            regexp_replace(normalize(lower(trim(stadium)), NFD), '\p{Mn}+', ''),
            '[^a-z0-9]+', ''
        )                                            as norm,
        max(city)                                    as city,
        max(country)                                 as country,
        max(venue_latitude)                          as latitude,
        max(venue_longitude)                         as longitude
    from iceberg.silver.sofascore_venue
    where stadium is not null
      and trim(stadium) <> ''
    group by 1, 2
),

unioned as (
    select * from fbref_venues
    union all
    select * from espn_venues
),

resolved as (
    select
        u.venue_raw,
        u.league,
        u.season,
        u.match_date,
        u.src,
        a.canonical_id,
        a.canonical_name,
        a.city                                       as city_curated,
        a.country                                    as country_curated,
        a.capacity                                   as capacity_curated,
        f.city                                       as city_fotmob,
        f.capacity                                   as capacity_fotmob,
        f.surface                                    as surface,
        f.opened                                     as opened,
        f.latitude,
        f.longitude,
        s.city                                       as city_sofascore,
        s.country                                    as country_sofascore,
        s.latitude                                   as latitude_sofascore,
        s.longitude                                  as longitude_sofascore,
        -- Curated alias -> explicit slug; orphan -> stable normalised-name hash.
        case
            when a.canonical_id is not null then a.canonical_id
            else 'venue_' || lower(to_hex(xxhash64(to_utf8(
                regexp_replace(
                    regexp_replace(normalize(lower(trim(u.venue_raw)), NFD), '\p{Mn}+', ''),
                    '[^a-z0-9]+', ''
                )
            ))))
        end                                          as venue_id
    from unioned u
    left join aliases a
      on a.league = u.league
     and a.norm = regexp_replace(
                      regexp_replace(normalize(lower(trim(u.venue_raw)), NFD), '\p{Mn}+', ''),
                      '[^a-z0-9]+', ''
                  )
    left join fotmob_venue f
      on f.league = u.league
     and f.norm = regexp_replace(
                      regexp_replace(normalize(lower(trim(u.venue_raw)), NFD), '\p{Mn}+', ''),
                      '[^a-z0-9]+', ''
                  )
    left join sofascore_venue s
      on s.league = u.league
     and s.norm = regexp_replace(
                      regexp_replace(normalize(lower(trim(u.venue_raw)), NFD), '\p{Mn}+', ''),
                      '[^a-z0-9]+', ''
                  )
),

aggregated as (
    select
        venue_id,
        max(canonical_id)                            as canonical_id,
        max(canonical_name)                          as canonical_name,
        max(city_curated)                            as city_curated,
        max(city_fotmob)                             as city_fotmob,
        max(country_curated)                         as country_curated,
        max(capacity_fotmob)                         as capacity_fotmob,
        max(capacity_curated)                        as capacity_curated,
        max(surface)                                 as surface,
        max(opened)                                  as opened,
        max(latitude)                                as latitude,
        max(longitude)                               as longitude,
        max(city_sofascore)                          as city_sofascore,
        max(country_sofascore)                       as country_sofascore,
        max(latitude_sofascore)                      as latitude_sofascore,
        max(longitude_sofascore)                     as longitude_sofascore,
        max(venue_raw) filter (where src = 'fbref')  as venue_fbref,
        max(venue_raw) filter (where src = 'espn')   as venue_espn,
        count(distinct match_date)                   as n_matches,
        min(match_date)                              as first_seen_date,
        max(match_date)                              as last_seen_date,
        max(league)                                  as league,
        max(season)                                  as season
    from resolved
    group by venue_id
)

select
    venue_id,
    coalesce(canonical_name, venue_fbref, venue_espn)                          as venue_name,
    -- city (issue #750/#753): curated venue_aliases.yaml wins; FotMob fills the
    -- NULLs, then SofaScore `event.venue.city` fills any still-NULL (moved /
    -- orphan grounds).
    coalesce(city_curated, city_fotmob, city_sofascore)                        as city,
    -- country (issue #753): curated wins; SofaScore `event.venue.country` fills the
    -- rest. FotMob carries TEAM country, not venue country — this was a followup
    -- (was curated-only) now closed by the SofaScore venue source.
    coalesce(country_curated, country_sofascore)                               as country,
    -- capacity (issue #750): FotMob silver.fotmob_team_profile is PRIMARY (auto +
    -- global, replaced the bulk of #434); COALESCE to a small curated FALLBACK for
    -- venues FotMob's current-ground team-profile can't supply (moved grounds like
    -- Goodison Park / White Hart Lane / Wembley). NULL only when neither has it.
    cast(coalesce(capacity_fotmob, capacity_curated) as integer)               as capacity,
    -- surface / opened (issue #750): new attributes from FotMob venue.statPairs.
    surface,
    cast(opened as integer)                                                    as opened,
    -- latitude/longitude (issue #719 + #753): FotMob stadium coords (matched by
    -- normalised venue name) are PRIMARY; SofaScore `event.venue.venueCoordinates`
    -- fills NULLs — notably moved grounds whose historical name FotMob can't match.
    cast(coalesce(latitude, latitude_sofascore) as double)                     as latitude,
    cast(coalesce(longitude, longitude_sofascore) as double)                   as longitude,
    -- Kept beyond the design's column list: the orphan-rate DQ check in
    -- gold_tasks.validate_gold_quality filters on venue_source = 'orphan'.
    case when canonical_id is not null then 'curated' else 'orphan' end        as venue_source
from aggregated
