# Целевой Caddyfile гибридной схемы (docs/HEADSCALE_MIGRATION.md):
#   - публичные из интернета: bi (Superset), auth (Keycloak), hs (Headscale)
#   - только из VPN: jupyter, airflow, trino, meta (403 для остальных)
# Активация на cutover: cp Caddyfile.hybrid.example Caddyfile (домен приходит
# Caddy-подстановкой {$PLATFORM_DOMAIN} из env сервиса caddy — рендер не нужен).
# Все A-записи (*.__домен__) смотрят на публичный IP — так Caddy получает
# LE-сертификаты по HTTP-01. Внутри VPN split-DNS (extra_records headscale)
# резолвит сервисные имена в headscale-IP VM, поэтому у VPN-клиентов
# remote_ip из 100.64.0.0/10.
# Caddy должен слушать и на публичном IP (${PUBLIC_IP}:80/:443 в compose),
# и на headscale-IP (${TS_IP}:443 — после cutover это headscale-адрес).

# --- Публичные ---------------------------------------------------------------

# Superset: дашборды для «простых» юзеров. Защита — Keycloak SSO
# (brute-force protection включён в realm).
https://bi.{$PLATFORM_DOMAIN} {
	reverse_proxy superset:8088
}

# Keycloak: обязан быть публичным — на него редиректят браузеры юзеров (OIDC).
# Админку наружу не отдаём: /admin — только из VPN.
https://auth.{$PLATFORM_DOMAIN} {
	@admin_not_vpn {
		path /admin* /admin/*
		not remote_ip 100.64.0.0/10
	}
	respond @admin_not_vpn 403
	reverse_proxy keycloak:8080
}

# Headscale: контрольный сервер VPN (клиенты ходят сюда при логине и keepalive).
https://hs.{$PLATFORM_DOMAIN} {
	reverse_proxy headscale:8080
}

# --- Только из VPN (headscale, 100.64.0.0/10) --------------------------------

https://jupyter.{$PLATFORM_DOMAIN} {
	@vpn remote_ip 100.64.0.0/10
	handle @vpn {
		reverse_proxy jupyterhub:8000
	}
	respond 403
}

https://airflow.{$PLATFORM_DOMAIN} {
	@vpn remote_ip 100.64.0.0/10
	handle @vpn {
		reverse_proxy airflow-webserver:8080
	}
	respond 403
}

# Trino говорит HTTPS сам (self-signed) — re-encrypt, как в текущей схеме.
https://trino.{$PLATFORM_DOMAIN} {
	@vpn remote_ip 100.64.0.0/10
	handle @vpn {
		reverse_proxy https://trino:8443 {
			transport http {
				tls
				tls_insecure_skip_verify
			}
		}
	}
	respond 403
}

https://meta.{$PLATFORM_DOMAIN} {
	@vpn remote_ip 100.64.0.0/10
	handle @vpn {
		reverse_proxy openmetadata-server:8585
	}
	respond 403
}
