# Публичная схема (без VPN): один listener :443 на ${PUBLIC_IP}.
# Гейт — Keycloak SSO у каждого сервиса (Superset/JupyterHub/Airflow — OAuth,
# Trino — PASSWORD для машинных + OAUTH2 для людей).
# /admin и master-realm Keycloak закрыты снаружи: админка — через SSH-туннель
# на 127.0.0.1:8180 (KC_HOSTNAME_ADMIN в compose.yaml).
# ACME HTTP-01: все A-записи -> ${PUBLIC_IP}, :80 опубликован там же.
# JSON access-log на /var/log/caddy (bind на хост) — его читает fail2ban.

(logging) {
	log {
		output file /var/log/caddy/access.log {
			roll_size 20MiB
			roll_keep 5
		}
		format json {
			time_format rfc3339
		}
	}
}

# Superset: дашборды. Защита — Keycloak SSO.
https://bi.{$PLATFORM_DOMAIN} {
	import logging
	reverse_proxy superset:8088
}

# Keycloak: публичен только юзер-флоу (realm football).
https://auth.{$PLATFORM_DOMAIN} {
	import logging
	@admin path /admin /admin/* /realms/master /realms/master/*
	respond @admin 403
	reverse_proxy keycloak:8080
}

https://jupyter.{$PLATFORM_DOMAIN} {
	import logging
	reverse_proxy jupyterhub:8000
}

https://airflow.{$PLATFORM_DOMAIN} {
	import logging
	reverse_proxy airflow-webserver:8080
}

# Trino говорит HTTPS сам (self-signed) — re-encrypt.
https://trino.{$PLATFORM_DOMAIN} {
	import logging
	reverse_proxy https://trino:8443 {
		transport http {
			tls
			tls_insecure_skip_verify
		}
	}
}

# OpenMetadata: каталог данных. Гейт — Keycloak SSO самого OM (custom-oidc,
# #866); self-signup выключен — входят только заведённые админом юзеры.
# Break-glass (OM_AUTH_* убраны из .env = basic) — этот блок закомментировать:
# basic-OM наружу не публикуется, доступ через SSH-туннель 127.0.0.1:8585.
https://meta.{$PLATFORM_DOMAIN} {
	import logging
	reverse_proxy openmetadata-server:8585
}
