{
  "realm": "football",
  "displayName": "Football Data Platform",
  "enabled": true,
  "registrationAllowed": true,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "sslRequired": "external",
  "bruteForceProtected": true,
  "browserSecurityHeaders": {
    "contentSecurityPolicy": "frame-src 'self' https://www.google.com; frame-ancestors 'self'; object-src 'none';",
    "contentSecurityPolicyReportOnly": "",
    "xContentTypeOptions": "nosniff",
    "xFrameOptions": "SAMEORIGIN",
    "referrerPolicy": "no-referrer",
    "xRobotsTag": "none",
    "strictTransportSecurity": "max-age=31536000; includeSubDomains"
  },
  "groups": [
    { "name": "analysts", "path": "/analysts" },
    { "name": "viewers", "path": "/viewers" },
    { "name": "platform-admins", "path": "/platform-admins" }
  ],
  "defaultGroups": ["/viewers"],
  "authenticatorConfig": [
    {
      "alias": "recaptcha",
      "config": {
        "site.key": "__KC_RECAPTCHA_SITE_KEY__",
        "secret.key": "__KC_RECAPTCHA_SECRET_KEY__",
        "useRecaptchaNet": "false",
        "recaptcha.v3": "false",
        "action": "register"
      }
    }
  ],
  "authenticationFlows": [
    {
      "alias": "registration",
      "description": "Registration flow (копия built-in: reCAPTCHA обязательна; остальные built-in flow Keycloak досоздаёт сам при импорте)",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": true,
      "authenticationExecutions": [
        {
          "authenticator": "registration-page-form",
          "authenticatorFlow": true,
          "requirement": "REQUIRED",
          "priority": 10,
          "flowAlias": "registration form",
          "userSetupAllowed": false
        }
      ]
    },
    {
      "alias": "registration form",
      "description": "Registration form",
      "providerId": "form-flow",
      "topLevel": false,
      "builtIn": true,
      "authenticationExecutions": [
        { "authenticator": "registration-user-creation", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 20, "userSetupAllowed": false },
        { "authenticator": "registration-password-action", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 50, "userSetupAllowed": false },
        { "authenticator": "registration-recaptcha-action", "authenticatorConfig": "recaptcha", "authenticatorFlow": false, "requirement": "REQUIRED", "priority": 60, "userSetupAllowed": false },
        { "authenticator": "registration-terms-and-conditions", "authenticatorFlow": false, "requirement": "DISABLED", "priority": 70, "userSetupAllowed": false }
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "description": "Группы пользователя в claim `groups` (на нём вся авторизация)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "preferred_username и имя (импорт создаёт ТОЛЬКО то, что в файле — встроенных скоупов в realm нет, поэтому определяем явно)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "email пользователя",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "basic",
      "description": "sub в access-токене",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "airflow",
      "name": "Airflow",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__AIRFLOW_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://airflow.__PLATFORM_DOMAIN__/oauth-authorized/keycloak"],
      "webOrigins": ["https://airflow.__PLATFORM_DOMAIN__"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "superset",
      "name": "Superset",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__SUPERSET_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://bi.__PLATFORM_DOMAIN__/oauth-authorized/keycloak"],
      "webOrigins": ["https://bi.__PLATFORM_DOMAIN__"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "jupyterhub",
      "name": "JupyterHub",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__JUPYTERHUB_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://jupyter.__PLATFORM_DOMAIN__/hub/oauth_callback"],
      "webOrigins": ["https://jupyter.__PLATFORM_DOMAIN__"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "trino",
      "name": "Trino",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__TRINO_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://trino.__PLATFORM_DOMAIN__/oauth2/callback"],
      "webOrigins": ["https://trino.__PLATFORM_DOMAIN__"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    }
  ]
}
