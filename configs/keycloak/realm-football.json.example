{
  "realm": "football",
  "displayName": "Football Data Platform",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "sslRequired": "external",
  "bruteForceProtected": true,
  "groups": [
    { "name": "analysts", "path": "/analysts" },
    { "name": "platform-admins", "path": "/platform-admins" }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "description": "Группы пользователя в claim `groups` (на нём вся авторизация)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "preferred_username и имя (импорт создаёт ТОЛЬКО то, что в файле — встроенных скоупов в realm нет, поэтому определяем явно)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "claim.name": "given_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "claim.name": "family_name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "email пользователя",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "claim.name": "email_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "basic",
      "description": "sub в access-токене",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "airflow",
      "name": "Airflow",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__AIRFLOW_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8081/oauth-authorized/keycloak"],
      "webOrigins": ["https://__TS_HOSTNAME__:8081"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "superset",
      "name": "Superset",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__SUPERSET_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8088/oauth-authorized/keycloak"],
      "webOrigins": ["https://__TS_HOSTNAME__:8088"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "jupyterhub",
      "name": "JupyterHub",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__JUPYTERHUB_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__/hub/oauth_callback"],
      "webOrigins": ["https://__TS_HOSTNAME__"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "trino",
      "name": "Trino",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__TRINO_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8444/oauth2/callback"],
      "webOrigins": ["https://__TS_HOSTNAME__:8444"],
      "defaultClientScopes": ["profile", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access"]
    }
  ]
}
