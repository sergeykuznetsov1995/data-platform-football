{
  "realm": "football",
  "displayName": "Football Data Platform",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "sslRequired": "external",
  "bruteForceProtected": true,
  "groups": [
    { "name": "analysts", "path": "/analysts" },
    { "name": "platform-admins", "path": "/platform-admins" }
  ],
  "clientScopes": [
    {
      "name": "groups",
      "description": "Группы пользователя в claim `groups` (на нём вся авторизация)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "airflow",
      "name": "Airflow",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__AIRFLOW_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8081/oauth-authorized/keycloak"],
      "webOrigins": ["https://__TS_HOSTNAME__:8081"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "superset",
      "name": "Superset",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__SUPERSET_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8088/oauth-authorized/keycloak"],
      "webOrigins": ["https://__TS_HOSTNAME__:8088"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "jupyterhub",
      "name": "JupyterHub",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__JUPYTERHUB_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__/hub/oauth_callback"],
      "webOrigins": ["https://__TS_HOSTNAME__"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "trino",
      "name": "Trino",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "__TRINO_OIDC_CLIENT_SECRET__",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["https://__TS_HOSTNAME__:8444/oauth2/callback"],
      "webOrigins": ["https://__TS_HOSTNAME__:8444"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email", "basic", "groups"],
      "optionalClientScopes": ["offline_access", "microprofile-jwt"]
    }
  ]
}
