# =============================================================================
# Data Platform Environment Variables (Example)
# =============================================================================
# Copy this file to .env and update values as needed

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=postgres

# Airflow
AIRFLOW_DB_PASSWORD=<your-airflow-db-password>
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=<generate-with-python-fernet>
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:<password>@postgres:5432/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:<password>@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:<redis-password>@redis:6379/0
AIRFLOW__WEBSERVER__SECRET_KEY=<your-secret-key>
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
_AIRFLOW_WWW_USER_CREATE=true
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=<your-admin-password>
_PIP_ADDITIONAL_REQUIREMENTS=
AIRFLOW_PROJ_DIR=.

# SeaweedFS / Iceberg object storage
S3_ACCESS_KEY=<your-s3-access-key>
S3_SECRET_KEY=<your-s3-secret-key>
ICEBERG_WAREHOUSE=warehouse
# Source raw/replay prefixes are derived from this bucket by compose.yaml.

# WhoScored concurrency (shared by daily and resumable backfill tasks)
WHOSCORED_DIRECT_POOL=whoscored_direct_pool
WHOSCORED_BACKFILL_POOL=whoscored_direct_pool
WHOSCORED_RAW_LOCK_TIMEOUT_SECONDS=55
# Structured JSON feeds: per task, one token per source URL. Production code
# rejects values outside 1..60; with the two-slot Airflow pool this caps the
# origin at 120 requests/minute and eight concurrent browser XHRs.
WHOSCORED_STRUCTURED_REQUESTS_PER_MINUTE=60
# Catalog discovery is a single task and uses a four-request burst. The code
# rejects values outside 1..60; raw hits do not consume source tokens.
WHOSCORED_CATALOG_REQUESTS_PER_MINUTE=60

# Hive Metastore
HIVE_METASTORE_DB_HOST=postgres
HIVE_METASTORE_DB_NAME=hive_metastore
HIVE_METASTORE_DB_USER=hive
HIVE_METASTORE_DB_PASSWORD=<your-hive-password>

# Redis
REDIS_PASSWORD=<your-redis-password>

# Spark
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_WEBUI_PORT=8080

# HDFS
HDFS_NAMENODE_HOST=namenode
HDFS_REPLICATION_FACTOR=2

# Java
JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64

# Trino
TRINO_PORT=8443
TRINO_HOST=trino
TRINO_PASSWORD=<your-trino-password>
TRINO_KEYSTORE_PASSWORD=<your-keystore-password>
# BI / Catalog service accounts (auth via configs/trino/password.db, bcrypt)
# IMPORTANT: configs/trino/password.db ships with bcrypt hashes generated from
# placeholder passwords ("superset_trino_pass_2026", "om_trino_pass_2026").
# Those placeholders are PUBLIC (.env.example is in git history).
# Before exposing Trino to anything beyond localhost, rotate BOTH:
#   1) generate new passwords and put them here in .env (NOT .env.example)
#   2) regenerate bcrypt hashes and rewrite configs/trino/password.db
#      htpasswd -B -C 10 -nb superset 'NEW_PASSWORD' >> configs/trino/password.db
#      htpasswd -B -C 10 -nb openmetadata 'NEW_PASSWORD' >> configs/trino/password.db
#   3) docker compose restart trino superset openmetadata-server openmetadata-ingestion
TRINO_SUPERSET_PASSWORD=<rotate-me-before-prod>
TRINO_OPENMETADATA_PASSWORD=<rotate-me-before-prod>

# Analyst access: Tailscale + Caddy (docs/design/analyst-access.md)
# TS_HOSTNAME: tailscale status --json | jq -r '.Self.DNSName' (без точки на конце)
# TS_IP:       tailscale ip -4
TS_HOSTNAME=<vm-name>.<tailnet>.ts.net
TS_IP=<100.x.y.z>

# Keycloak (SSO). Секреты: openssl rand -hex 32
# После заполнения: make keycloak-db && make render-keycloak-realm
KEYCLOAK_DB_PASSWORD=<openssl-rand-hex-32>
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<openssl-rand-hex-32>
AIRFLOW_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
SUPERSET_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
JUPYTERHUB_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
TRINO_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
OPENMETADATA_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
# Фикс. ключ шифрования OAuth2 refresh-токенов Trino (config.properties
# refresh-tokens.secret-key). Без него рестарт Trino разлогинивает аналитиков.
TRINO_OAUTH2_REFRESH_KEY=<openssl-rand-hex-32>
# Общий read-only аккаунт для ноутбуков (bcrypt-хэш в configs/trino/password.db).
# -C 10 обязателен: дефолтный cost 5 < минимума Trino 8 — битая строка ломает весь password.db:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB -C 10 analyst_svc '<пароль>' >> configs/trino/password.db
TRINO_ANALYST_SVC_PASSWORD=<openssl-rand-hex-32>

# Гибрид: Headscale + публичные Superset/Keycloak (docs/HEADSCALE_MIGRATION.md).
# До cutover всё ниже НЕ заполняется — платформа живёт на tailnet-дефолтах.
# PLATFORM_DOMAIN: свой домен (A-записи bi/auth/hs/jupyter/airflow/trino/meta -> PUBLIC_IP)
# PUBLIC_IP: публичный IP VM (вход bi/auth/hs + ACME)
#PLATFORM_DOMAIN=<your-domain.com>
#PUBLIC_IP=<x.x.x.x>
#HEADSCALE_OIDC_CLIENT_SECRET=<openssl-rand-hex-32>
#COMPOSE_PROFILES=headscale
# Cutover-переключатели (пустые = tailnet-схема; значения — см. миграционный док):
#OIDC_ISSUER=https://auth.<your-domain.com>/realms/football
#KC_PUBLIC_URL=https://auth.<your-domain.com>
#JUPYTER_PUBLIC_HOST=jupyter.<your-domain.com>
#TRINO_PUBLIC_HOST=trino.<your-domain.com>
#TRINO_PUBLIC_PORT=443

# Alerts (optional — leave empty to disable Telegram notifications)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-telegram-chat-id>
ALERT_ENV=dev

# Scrapers / Cloudflare bypass
# FlareSolverr — proxy that solves Cloudflare challenges for HTTP scrapers
# (sidecar service in compose.yaml, on the same network as airflow workers)
FLARESOLVERR_URL=http://flaresolverr:8191

# Metered residential-proxy lease service. SofaScore's DagRun cap is not set
# here: proxy_filter derives it exclusively from the reviewed canary artifact
# and refuses SofaScore leases while that artifact is unverified.
SOFASCORE_PROXY_CONTROL_URL=http://proxy_filter:8899
# Generate once with `openssl rand -hex 32`; the proxy and Airflow share it.
SOFASCORE_PROXY_CONTROL_TOKEN=
SOFASCORE_PROXY_LEASE_TTL_SECONDS=3600
# FBref uses a separate proxy-filter process and a separately mounted proxy
# file, but the same control secret. All values below are hard provider-wire
# ceilings, not estimates from response bodies.
FBREF_PROXY_CONTROL_URL=http://fbref_proxy_filter:8899
FBREF_PROXY_LEASE_TTL_SECONDS=7200
FBREF_PROXY_DAILY_BUDGET_MB=300
FBREF_PROXY_MAX_LEASE_MB=100
FBREF_PROXY_MAX_LEASE_TTL_SECONDS=7200
FBREF_PROXY_DAGRUN_BUDGET_BYTES=104857600
FBREF_PROXY_URL_BUDGET_BYTES=104857600
# Safe production default; only fenced, proven-stale generic stages are removed.
FBREF_STAGE_JANITOR_MODE=apply
# Shared, durable directory for immutable HMAC-signed DagRun phase plans.
SOFASCORE_WORKLOAD_PLAN_DIR=/opt/airflow/logs/sofascore/workload-plans
# The Saturday player phase is the heaviest paid slice, so each club league
# refreshes its player universe once every SOFASCORE_PLAYER_ROTATION_MODULUS
# weeks. The rotation only engages once the active club-league count reaches
# SOFASCORE_PLAYER_ROTATION_MIN_LEAGUES; below it every league is due weekly.
# Cups are always due. Matches and standings are never rotated.
SOFASCORE_PLAYER_ROTATION_MODULUS=4
SOFASCORE_PLAYER_ROTATION_MIN_LEAGUES=10
# Transfermarkt native-v2 is fail-closed until an exact paid/write packet is
# approved. The proxy filter keeps WhoScored at 8,000,000 bytes per DagRun and
# grants only the two Transfermarkt DAGs the 336 MiB per-DagRun ceiling that
# matches PARENT_DAILY_HARD_PROVIDER_BYTE_CAP; the 400 MB/day pool, this cap
# and the canon pair in scrapers/transfermarkt/models.py move only together.
TM_NATIVE_V2_ENABLED=false
# Second key of the standing-policy activation: scheduled ingest runs accept
# dags/configs/transfermarkt/standing_approval_policy.json only when true.
# Must also be added to the x-airflow-common environment block in compose.yaml
# (an explicit whitelist) or the gate never reaches the Airflow containers.
TM_STANDING_POLICY_ENABLED=false
TM_PROXY_CONTROL_URL=
TM_REQUIRE_METERED_PROXY=false
TM_PROXY_LEASE_TTL_SECONDS=3600
PROXY_FILTER_DAILY_BUDGET_MB=400
PROXY_FILTER_MAX_LEASE_MB=24
PROXY_FILTER_MAX_LEASE_TTL_SECONDS=3600
PROXY_FILTER_DAGRUN_BUDGET_BYTES=8000000
PROXY_FILTER_TRANSFERMARKT_DAGRUN_BUDGET_BYTES=352321536
PROXY_FILTER_URL_BUDGET_BYTES=2000000
PROXY_FILTER_MAX_ACTIVE_LEASES=4
# Bootstrap only: set an explicit experimental byte cap while running the
# isolated dag_canary_sofascore_proxy cohort; 0 disables canary paid traffic.
# This value never authorizes dag_ingest_sofascore production capture.
PROXY_FILTER_SOFASCORE_CANARY_HARD_CAP_BYTES=0
# Hard byte cap for one metered SofaScore registry discovery scan
# (dag_discover_sofascore_registry / `make sofascore-discovery-lease`). The
# default 0 refuses every discovery lease; discovery normally runs over the
# direct zero-paid-byte transport and needs the residential pool only for an
# authorized catalog fan-out.
PROXY_FILTER_SOFASCORE_DISCOVERY_DAGRUN_BUDGET_BYTES=0
# Required by proxy_filter. Keep this single-line value only in the real secret
# environment (never commit it). Schema:
# [{"host":"pool.example","port":10000,"username":"...","password":"..."}]
# When stored in a Compose .env file, single-quote the whole JSON value.
PROXY_POOL_JSON=
# Emergency rolling-migration escape hatch. Default false means env-only; using
# true also requires an explicit proxy_filter volume override for --proxy-file.
PROXY_FILTER_ALLOW_FILE_FALLBACK=false

# Superset (BI / Dashboards)
# SUPERSET_SECRET_KEY: generate with `openssl rand -base64 42`
SUPERSET_DB_PASSWORD=
SUPERSET_SECRET_KEY=
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=

# OpenMetadata (Data Catalog)
OPENMETADATA_DB_PASSWORD=
# JWT token for ingestion-bot — UI → Settings → Bots → ingestion-bot
# Used by metadata CLI to authenticate Trino metadata + lineage workflows
# (see configs/openmetadata/README.md). После ротации RSA-ключей (ниже)
# токен обязателен к перевыпуску.
OM_JWT_TOKEN=

# Свой RSA keypair для подписи бот-JWT вместо публично известного дефолта
# образа. Генерация: make gen-om-jwt-keys. ОБЯЗАТЕЛЬНО до публикации meta.
# Ключи живут ВНЕ SSO-блока: break-glass (откат в basic) их НЕ трогает,
# иначе умрут все бот-токены.
#OM_RSA_PUBLIC_KEY_FILE_PATH=/etc/openmetadata/jwtkeys/public_key.der
#OM_RSA_PRIVATE_KEY_FILE_PATH=/etc/openmetadata/jwtkeys/private_key.der
#OM_JWT_ISSUER=meta.<your-domain.com>
#OM_JWT_KEY_ID=<uuidgen>

# OpenMetadata SSO через Keycloak (custom-oidc, #866). Закомментировано = basic.
# Break-glass: закомментировать блок (RSA-ключи выше оставить!), убрать
# meta-блок из Caddyfile и docker compose --profile heavy up -d openmetadata-server.
# Перед включением: клиент openmetadata в живом Keycloak (kcadm — --import-realm
# существующий realm НЕ обновляет; см. configs/openmetadata/README.md).
#OM_AUTH_PROVIDER=custom-oidc
#OM_AUTH_CLIENT_TYPE=confidential
#OM_AUTH_PROVIDER_NAME=KeyCloak
#OM_AUTH_AUTHORITY=https://auth.<your-domain.com>/realms/football
#OM_AUTH_CLIENT_ID=openmetadata
#OM_AUTH_CALLBACK_URL=https://meta.<your-domain.com>/callback
#OM_AUTH_PUBLIC_KEYS=[http://localhost:8585/api/v1/system/config/jwks, https://auth.<your-domain.com>/realms/football/protocol/openid-connect/certs]
#OM_AUTH_ENABLE_SELF_SIGNUP=false
#OM_AUTH_PRINCIPAL_CLAIMS=[preferred_username,email,sub]
# Админы OM = KC-username из platform-admins (OM OSS не маппит группы в роли)
#OM_ADMIN_PRINCIPALS=[admin,sergey]
#OM_OIDC_DISCOVERY_URI=https://auth.<your-domain.com>/realms/football/.well-known/openid-configuration
#OM_PUBLIC_URL=https://meta.<your-domain.com>
