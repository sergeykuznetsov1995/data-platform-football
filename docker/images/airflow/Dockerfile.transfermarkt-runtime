# Production-safe overlay for Transfermarkt's native TLS transport.
#
# The live Airflow runtime is newer than the repository's legacy full-image
# Dockerfile.  Build this small overlay on the already verified production
# runtime base; do not re-resolve or downgrade the shared Airflow environment.
ARG AIRFLOW_RUNTIME_BASE=data-platform-airflow-webserver:latest
FROM ${AIRFLOW_RUNTIME_BASE}

USER airflow
# These exact packages make the local webserver runtime package-identical to
# the current scheduler.  --no-deps prevents unrelated dependency drift.
RUN pip install --no-cache-dir --no-deps \
        aenum==3.1.17 \
        astronomer-cosmos==1.14.2 \
        deprecation==2.1.0
RUN pip install --no-cache-dir --no-deps wrapper-tls-requests==1.2.5

# wrapper-tls-requests ships without its native library and otherwise performs
# an unmetered GitHub download on the first Client().  Bake a checksum-pinned,
# root-owned copy and force the explicit path.  Missing/corrupt files then fail
# closed without entering the runtime downloader.
USER root
RUN install -d -o root -g root -m 0755 /opt/tls-client \
    && curl --proto '=https' --tlsv1.2 -fsSL \
        --proto-redir '=https' \
        "https://github.com/bogdanfinn/tls-client/releases/download/v1.13.1/tls-client-linux-ubuntu-amd64-1.13.1.so" \
        -o /opt/tls-client/tls-client.so \
    && echo "e4a4a5d771d1bd1558186a5ee46af1dfa1318bd31950d68ccd81ed30bad078fc  /opt/tls-client/tls-client.so" \
        | sha256sum -c - \
    && chmod 0444 /opt/tls-client/tls-client.so
ENV TLS_LIBRARY_PATH=/opt/tls-client/tls-client.so

USER airflow
# Client construction loads the shared library but performs no HTTP request.
RUN python -c "import tls_requests; client = tls_requests.Client(proxy='http://127.0.0.1:9'); client.close()"
WORKDIR /opt/airflow
